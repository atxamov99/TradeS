# ── Application ──
PORT=5000
NODE_ENV=development

# ── Database ──
DATABASE_URL="postgresql://user:password@host:port/db?sslmode=require"

# ── JWT ──
JWT_ACCESS_SECRET=change_me_to_random_64hex
JWT_REFRESH_SECRET=change_me_to_random_64hex
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d
JWT_EXPIRES_IN=24h

# ── Security ──
BCRYPT_SALT_ROUNDS=10
ADMIN_SETUP_KEY=change_me_to_random_64hex
# Password used by `node src/seedAdmin.js` for the seeded admin@savdo.uz account.
# Required for seeding — never commit a real value.
ADMIN_SEED_PASSWORD=change_me_strong_password

# ── CORS ──
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
CLIENT_URL=http://localhost:5173

# ── Telegram OTP bot ──
# Token from @BotFather for trades_uz_bot. Locally the backend long-polls
# Telegram for updates (no public URL needed); production uses a webhook
# pointed at the deployed Render URL.
TELEGRAM_BOT_TOKEN=

# Comma-separated numeric Telegram chat_ids (from @userinfobot, or a support
# group's id) that "Contact Support" messages from the app get forwarded to.
ADMIN_SUPPORT_CHAT_IDS=

# ── SMS (dev) ──
SMS_DEMO=true
# ESKIZ_TOKEN=

# ── SMTP (MailDev) ──
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=noreply@savdo.local
SMTP_PASS=irrelevant

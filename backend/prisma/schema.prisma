generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum ShopMemberRole {
  OWNER
  CASHIER
}

model User {
  id              String         @id @default(cuid())
  name            String
  email           String?        @unique
  password        String
  role            Role           @default(USER)
  avatar          String?
  phone           String?
  telegram        String?
  instagram       String?
  addresses       Address[]
  isBlocked       Boolean        @default(false)
  isEmailVerified Boolean        @default(false)
  deletedAt       DateTime?      // soft delete: set when a user with linked history is "deleted"
  lastLogin       DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  isTestUser      Boolean        @default(false)
  testExpiresAt   DateTime?
  testActionCount Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  products        Product[]      @relation("CreatedBy")
  ownedProducts   Product[]      @relation("Owner")
  orders          Order[]
  sales           Sale[]
  cashierSales    Sale[]         @relation("Cashier")
  cart            Cart?
  wishlist        Wishlist?
  refreshTokens   RefreshToken[]
  inventoryBatches InventoryBatch[]
  syncQueues      SyncQueue[]
  ownedShops      Shop[]         @relation("ShopOwner")
  shopMemberships ShopMember[]
  expenses        Expense[]      @relation("ExpenseCreatedBy")
}

model Shop {
  id        String       @id @default(cuid())
  name      String
  ownerId   String
  owner     User         @relation("ShopOwner", fields: [ownerId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  members   ShopMember[]
  products  Product[]
  sales     Sale[]
  expenses  Expense[]

  @@index([ownerId])
}

model ShopMember {
  id        String         @id @default(cuid())
  shopId    String
  shop      Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ShopMemberRole @default(CASHIER)
  createdAt DateTime       @default(now())

  @@unique([shopId, userId])
  @@index([userId])
}

model Address {
  id        String  @id @default(cuid())
  label     String  @default("Home")
  street    String
  city      String
  state     String
  country   String
  zipCode   String
  isDefault Boolean @default(false)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  buyPrice    Float    @default(0)
  sellPrice   Float    @default(0)
  unit        String   @default("dona")
  bagWeightKg Float?
  barcode     String?
  description String   @default("")
  price       Float    @default(0)
  discount    Float    @default(0)
  finalPrice  Float    @default(0)
  category    String   @default("")
  stock       Float    @default(0)
  brand       String   @default("")
  tags        String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId     String?
  owner       User?    @relation("Owner", fields: [ownerId], references: [id])
  createdById String?
  createdBy   User?    @relation("CreatedBy", fields: [createdById], references: [id])
  shopId      String?
  shop        Shop?    @relation(fields: [shopId], references: [id])

  images      ProductImage[]
  reviews     Review[]
  orders      OrderItem[]
  sales       Sale[]
  cartItems   CartItem[]
  wishlists   Wishlist[]
  inventoryBatches InventoryBatch[]

  @@index([slug])
  @@index([category])
  @@index([price])
  @@index([ownerId])
  @@index([createdById])
  @@index([shopId])
  @@index([barcode])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String  @default("")
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  name      String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  orderNumber     String      @unique
  paymentMethod   String      @default("cash_on_delivery")
  paymentStatus   String      @default("pending")
  orderStatus     String      @default("pending")
  itemsPrice      Float
  shippingPrice   Float       @default(0)
  taxPrice        Float       @default(0)
  totalPrice      Float
  paidAt          DateTime?
  deliveredAt     DateTime?
  notes           String      @default("")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           OrderItem[]
  shippingAddress ShippingAddress?

  @@index([userId])
  @@index([orderStatus])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  image     String  @default("")
  price     Float
  quantity  Int
}

model ShippingAddress {
  id        String @id @default(cuid())
  orderId   String @unique
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  street    String
  city      String
  state     String
  country   String
  zipCode   String
}

model Sale {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  productId     String?
  product       Product? @relation(fields: [productId], references: [id])
  productName   String
  externalProductId String? // local mobile ID for offline sync
  quantity      Float
  unit          String   @default("pcs")
  sellPrice     Float
  buyPrice      Float
  totalRevenue  Float    @default(0)
  totalCost     Float    @default(0)
  profit        Float    @default(0)
  note          String   @default("")
  syncId        String?  @unique
  isFromOffline Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shopId        String?
  shop          Shop?    @relation(fields: [shopId], references: [id])
  cashierId     String?
  cashier       User?    @relation("Cashier", fields: [cashierId], references: [id])

  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([shopId, createdAt])
}

model Expense {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  amount      Float
  category    String   @default("other")
  note        String   @default("")
  createdById String
  createdBy   User     @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId, createdAt])
}

model Cart {
  id         String     @id @default(cuid())
  userId     String     @unique
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalItems Int        @default(0)
  totalPrice Float      @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  items      CartItem[]
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model InventoryBatch {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  productName String
  quantity    Float
  unit        String   @default("pcs")
  buyPrice    Float
  totalCost   Float?
  note        String   @default("")
  syncId      String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([productId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  userAgent String   @default("")
  ip        String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

model SyncQueue {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  operation      String
  entity         String
  entityId       String
  serverEntityId String?
  payload        Json
  status         String   @default("pending")
  attempts       Int      @default(0)
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
}

model Content {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("landing_page")
  status    String   @default("draft")
  owner     String   @default("")
  body      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A one-way "contact support" message from the app, forwarded to a fixed
// Telegram chat (ADMIN_SUPPORT_CHAT_ID). Not a two-way chat — the admin
// replies personally via Telegram DM outside this system. Auto-deleted
// after 24h by a cleanup sweep (see server.js) so these never accumulate.
model SupportMessage {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  contact   String
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  category  String   @default("user")
  actor     String   @default("")
  actorId   String?
  target    String   @default("")
  targetId  String?
  ip        String   @default("")
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([category, createdAt])
  @@index([actorId])
}

model Wishlist {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

// App-wide admin configuration as key-value JSON blobs. Backs the admin panel's
// Settings, Roles (roles catalog), and Permissions (permission matrix) pages,
// which persist arbitrary config that is not enforced by the enum Role system.
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Phone auth via Telegram bot OTP.
// The bot writes telegramChatId when a user shares their contact; OTP codes are
// generated on request-otp and cleared on verify. Persists independently of User
// (contact can be linked before an account exists).
model PhoneAuth {
  id             String    @id @default(cuid())
  phone          String    @unique
  telegramChatId String?
  otpCode        String?
  otpExpiresAt   DateTime?
  attempts       Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// Email auth OTP (delivered via Resend). Analog of PhoneAuth for the email channel:
// codes are generated on request-email-otp and cleared on verify. Persists
// independently of User (a code can be requested before an account exists).
model EmailAuth {
  id           String    @id @default(cuid())
  email        String    @unique
  otpCode      String?
  otpExpiresAt DateTime?
  attempts     Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
